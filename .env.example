# ============================================================================
# Financial Dashboard — Environment Variables Template
# ============================================================================
# Copy this file to `.env` and fill in values. NEVER commit `.env` to git.
# ============================================================================

# ----------------------------------------------------------------------------
# Dashboard API Auth (existing)
# ----------------------------------------------------------------------------
# Set this to require X-API-Key header on /api/* endpoints.
# Leave empty to disable auth (local dev only).
DASHBOARD_API_KEY=

# Pipeline auto-refresh interval in minutes (0 to disable).
DASHBOARD_REFRESH_MINUTES=30

# ----------------------------------------------------------------------------
# AI Advisor — Phase 1+ (not yet active)
# ----------------------------------------------------------------------------
# Claude API key from https://console.anthropic.com
# Create account -> add credit card -> generate key -> paste below.
ANTHROPIC_API_KEY=

# Primary model for reasoning-heavy tasks (chat, investigator, advisor).
# Verified live as of 2026-04-17. Available: claude-opus-4-7, claude-sonnet-4-6,
# claude-opus-4-6, claude-sonnet-4-5-20250929, claude-haiku-4-5-20251001.
AI_MODEL=claude-sonnet-4-6

# Fallback model for simple queries (cheaper, faster).
AI_MODEL_FALLBACK=claude-haiku-4-5-20251001

# Safety caps for LLM responses.
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# Monthly budget cap in USD. AI will refuse requests if exceeded.
AI_BUDGET_CAP_USD=100
AI_BUDGET_WARN_PCT=80

# Rate limit per hour (per user) for /api/chat endpoint.
AI_RATE_LIMIT_PER_HOUR=60

# ----------------------------------------------------------------------------
# Telegram Bot — Phase 3 (not yet active)
# ----------------------------------------------------------------------------
# Get token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Your private chat_id (send /start to bot, check logs to get it).
TELEGRAM_CHAT_ID=

# Mute until ISO datetime (e.g. 2026-05-01T09:00:00Z). Leave empty = active.
TELEGRAM_MUTE_UNTIL=

# ----------------------------------------------------------------------------
# AI Feature Flags
# ----------------------------------------------------------------------------
AI_FEATURE_DAILY_BRIEFING=true
AI_FEATURE_ANOMALY_ALERTS=true
AI_FEATURE_VOICE=false
AI_FEATURE_WEEKLY_REVIEW=true

# ----------------------------------------------------------------------------
# AI Storage Paths (relative to project root)
# ----------------------------------------------------------------------------
AI_MEMORY_DB_PATH=./ai_memory.db
AI_VECTOR_DB_PATH=./ai_vectors/
AI_LOG_PATH=./logs/ai.log
