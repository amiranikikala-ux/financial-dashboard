{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat .claude/hooks/session_start_reminder.json",
            "shell": "bash",
            "timeout": 5,
            "statusMessage": "Loading session governance reminder"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check_regression.sh",
            "shell": "bash",
            "timeout": 10,
            "statusMessage": "Checking for language regression"
          }
        ]
      }
    ]
  }
}
